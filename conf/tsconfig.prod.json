{
    "compilerOptions": {
        "target": "ES2018",
        "module": "commonjs",
        "moduleResolution": "node",
        "ignoreDeprecations": "6.0",
        "sourceMap": false,
        "removeComments": true,
        "experimentalDecorators": true,
        "strict": false,
        "skipLibCheck": true,
        "rootDir": "../src",
        "noImplicitReturns": true,
        "typeRoots": [
            "../node_modules/@types"
        ],
        "types": [
            "jquery",
            "node"
        ]
    },
    "include": [
        "../src/**/*"
    ],
    "exclude": [
        "../node_modules/*"
    ]
}
